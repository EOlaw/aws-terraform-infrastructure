# Local .terraform directories
**/.terraform/*

# State files -- these belong in the remote backend, never in git
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files that may contain sensitive data, except examples
*.tfvars
*.tfvars.json
!example.tfvars
!environments/**/terraform.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Plan output
*.tfplan
